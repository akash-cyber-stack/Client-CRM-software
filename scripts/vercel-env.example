# Copy to scripts/vercel-env.local (gitignored) — paste your Neon + secrets, then run:
#   powershell -File scripts/push-vercel-env.ps1

DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
