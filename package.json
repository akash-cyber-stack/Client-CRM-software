{
  "name": "sales-lead-crm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate --schema=backend/prisma/schema.prisma",
    "vercel-install": "npm install && npm install --prefix frontend",
    "vercel-build": "prisma generate --schema=backend/prisma/schema.prisma && npm run build --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma"
  }
}
