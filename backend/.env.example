# Server
PORT=5000
NODE_ENV=development

# Database
# SQLite (local dev - default)
DATABASE_URL="file:./dev.db"
# PostgreSQL local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/sales_lead_crm?schema=public"

# PostgreSQL Neon (Vercel production) — paste from Neon Console, never commit real URL
# DATABASE_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# Webhook secrets (verify incoming webhooks)
GOOGLE_WEBHOOK_SECRET=your-google-webhook-secret
META_WEBHOOK_VERIFY_TOKEN=your-meta-verify-token
META_WEBHOOK_SECRET=your-meta-webhook-secret
IVR_WEBHOOK_SECRET=your-ivr-webhook-secret

# Default super admin (used only on first seed)
ADMIN_EMAIL=admin@salesleadcrm.com
ADMIN_PASSWORD=Admin@123
