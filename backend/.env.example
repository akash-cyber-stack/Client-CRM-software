# Server
PORT=5000
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# Database — Neon cloud (https://console.neon.tech)
# Runtime: use POOLED host (-pooler in hostname) + pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Migrations: use DIRECT host (no -pooler)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# GST verification: mock (dev) | format (checksum only) | api (live registry)
GST_VERIFICATION_MODE=mock
GST_API_KEY=
GST_API_URL=
GST_MOCK_MOBILE=9876543210
GST_MOCK_EMAIL=

# GST OTP (required for new company registration)
GST_OTP_REQUIRED=true
GST_OTP_EXPIRY_MINUTES=10
GST_OTP_DEV_EXPOSE=true

# Auth email OTP (login/register) — codes go to inbox only, never shown in UI
AUTH_EMAIL_OTP_REQUIRED=true
AUTH_PHONE_OTP_REQUIRED=false
AUTH_OTP_EXPIRY_MINUTES=10
AUTH_OTP_DEV_EXPOSE=false

# Real OTP — Gmail App Password (NOT your normal Gmail password):
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Real payment gateway (Razorpay) — supports UPI, cards, netbanking, wallets
# Required for local payment checkout (same keys as Vercel production):
#   cd .. && npx vercel env pull .env.vercel.pull --environment=production
#   Copy RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET into backend/.env
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional custom SMS gateway (GST OTP mobile only — auth uses email OTP)
SMS_HTTP_URL=
SMS_API_KEY=
SMTP_HTTP_URL=
SMTP_API_KEY=

# OAuth — add redirect URIs in each provider console:
#   Google:    {API_BASE_URL}/api/auth/oauth/google/callback
#   Microsoft: {API_BASE_URL}/api/auth/oauth/microsoft/callback
#   GitHub:    {API_BASE_URL}/api/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Webhook secrets (per company in Settings; these are fallbacks)
GOOGLE_WEBHOOK_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_WEBHOOK_SECRET=
IVR_WEBHOOK_SECRET=

# Webhook URLs must include company GST, e.g.:
# POST /api/webhooks/google-leads?gstin=22AAAAA0000A1Z5
